   "source": [
    "## 5. Final Summary Card"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f3000012",
   "metadata": {},
   "outputs": [],
   "source": [
    "from src.utils.visualization import save_result_plot\n",
    "\n",
    "# Radar chart: our system vs baseline\n",
    "import matplotlib.patches as mpatches\n",
    "from matplotlib.patches import FancyArrowPatch\n",
    "\n",
    "categories = ['MOTA', 'IDF1', 'ID Stability', 'Energy Eff.', 'FPS', 'Mission Dur.']\n",
    "n = len(categories)\n",
    "angles = np.linspace(0, 2 * np.pi, n, endpoint=False).tolist()\n",
    "angles += angles[:1]  # close the radar\n",
    "\n",
    "# Normalised [0,1]: higher always = better\n",
    "ours     = [0.832, 0.785, 1 - 11/150, 1 - 274/500, 22.2/40, 0.72]\n",
    "baseline = [0.674, 0.618, 1 - 94/150, 1 - 420/500, 35.7/40, 0.00]\n",
    "ours     += ours[:1]\n",
    "baseline += baseline[:1]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 8), subplot_kw=dict(polar=True))\n",
    "fig.patch.set_facecolor('#111111')\n",
    "ax.set_facecolor('#1a1a1a')\n",
    "\n",
    "ax.plot(angles, ours, color=ACCENT, linewidth=2.5, linestyle='solid', label='PPO (ours)')\n",
    "ax.fill(angles, ours, color=ACCENT, alpha=0.25)\n",
    "ax.plot(angles, baseline, color='#ff4488', linewidth=2, linestyle='dashed', label='Baseline')\n",
    "ax.fill(angles, baseline, color='#ff4488', alpha=0.12)\n",
    "\n",
    "ax.set_xticks(angles[:-1])\n",
    "ax.set_xticklabels(categories, color='white', fontsize=12)\n",
    "ax.set_ylim(0, 1)\n",
    "ax.set_yticks([0.25, 0.5, 0.75, 1.0])\n",
    "ax.set_yticklabels(['0.25', '0.5', '0.75', '1.0'], color='gray', fontsize=8)\n",
    "ax.grid(color='#444444')\n",
    "ax.tick_params(colors='white')\n",
    "\n",
    "ax.legend(loc='upper right', bbox_to_anchor=(1.3, 1.15),\n",
    "          facecolor='#222222', labelcolor='white', fontsize=12)\n",
    "ax.set_title('System Performance Radar\\nAIC-4 Aerial Tracking', color='white',\n",
    "             fontsize=14, pad=20)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(ROOT / 'experiments/results/results_radar.png', dpi=150,\n",
    "            facecolor='#111111', bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print('\\n' + '='*60)\n",
    "print('  AIC-4 FINAL RESULTS SUMMARY')\n",
    "print('='*60)\n",
    "for metric, achieved in FINAL.items():\n",
    "    target = TARGETS[metric]\n",
    "    met = (achieved >= target) if metric not in LOWER_BETTER else (achieved <= target)\n",
    "    icon = '✅' if met else '❌'\n",
    "    print(f'  {icon} {metric:<30} target={target}   achieved={achieved}')\n",
    "print('='*60)\n",
    "print('\\n✅ All results saved to experiments/results/')"
   ]
  }
