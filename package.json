{
  "name": "aeromind-sentinel-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript build pipeline for AeroMind Sentinel dashboard risk modules.",
  "type": "module",
  "scripts": {
    "build:ts": "tsc -p tsconfig.json",
    "check:ts": "tsc -p tsconfig.json --noEmit",
