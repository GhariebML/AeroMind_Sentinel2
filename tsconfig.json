{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "dashboard/static/js",
    "rootDir": "dashboard/static/ts",
    "declaration": false,
    "sourceMap": false,
    "skipLibCheck": true
  },
  "include": ["dashboard/static/ts/**/*.ts"]
}
